# COMMAND ----------

import json
import requests
from datetime import datetime
from pyspark.sql import Row

from config.environment import API_KEY, BASE_URL

# COMMAND ----------

# Create catalog/schema if not already created

spark.sql("CREATE CATALOG IF NOT EXISTS fifa_worldcup")
spark.sql("USE CATALOG fifa_worldcup")

spark.sql("CREATE SCHEMA IF NOT EXISTS bronze")

# COMMAND ----------

# API Request

headers = {
    "x-apisports-key": API_KEY
}

params = {
    "league": 1,
    "season": 2025
}

response = requests.get(
    f"{BASE_URL}/fixtures",
    headers=headers,
    params=params,
    timeout=30
)

response.raise_for_status()

payload = response.json()

# COMMAND ----------

# Create Bronze Table

spark.sql("""
CREATE TABLE IF NOT EXISTS bronze.fixtures_raw (
    ingestion_ts TIMESTAMP,
    payload STRING
)
USING DELTA
""")

# COMMAND ----------

# Write Raw JSON

df = spark.createDataFrame([
    Row(
        ingestion_ts=datetime.utcnow(),
        payload=json.dumps(payload)
    )
])

(
    df.write
      .format("delta")
      .mode("append")
      .saveAsTable("bronze.fixtures_raw")
)

# COMMAND ----------

display(
    spark.sql("""
        SELECT *
        FROM bronze.fixtures_raw
        ORDER BY ingestion_ts DESC
        LIMIT 5
    """)
)